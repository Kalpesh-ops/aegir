# Frontend environment template — copy to frontend/.env.local and fill in.
#
# All three values are safe to expose to the browser (NEXT_PUBLIC_*):
#   - The Supabase anon key is meant for client use; row-level security
#     policies (see ../supabase/policies.sql) enforce per-user isolation.
#   - The API URL points at the local FastAPI backend.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
