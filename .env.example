# Backend Environment Variables (.env)
#
# This file contains credentials needed for the NetSec AI Scanner backend.
# Do NOT commit a populated .env to version control.
#
# Setup:
#   1. cp .env.example .env
#   2. Fill in the values below with your actual credentials
#   3. .env is already listed in .gitignore — keep it that way
#
# Local development:
#   - Get GOOGLE_API_KEY from: https://aistudio.google.com/app/apikey
#   - Create a Supabase project: https://supabase.com/dashboard
#     - Copy the Project URL, anon key, and SERVICE ROLE key (backend only)
#     - Run the SQL in ./supabase/policies.sql against the project to enable
#       row-level security on the ``scans`` and ``user_consent`` tables.

# ── Required ───────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
# Required by src/database/supabase_client.py for server-side inserts/deletes.
# Treat this key as a secret — it bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Optional ───────────────────────────────────────────────────────────────
# Comma-separated hostnames allowed by TrustedHostMiddleware. Defaults to
# loopback; override only if you front the backend with a reverse proxy.
ALLOWED_HOSTS=localhost,127.0.0.1

# Extra CORS origins (comma separated). Useful for a hosted staging frontend.
# EXTRA_CORS_ORIGINS=https://staging.example.com

# Override JWT audience/issuer if you are not using the Supabase defaults.
# SUPABASE_JWT_AUDIENCE=authenticated
# SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1

# Override the default bind host/port.
# NETSEC_BIND_HOST=127.0.0.1
# NETSEC_BIND_PORT=8000

# Force a specific packet-capture interface (otherwise auto-detected).
# TSHARK_INTERFACE=Ethernet
